{
  "log": {
    "loglevel": "warning"
  },
  "inbounds": [
    {
      "port": 12001,
      "listen": "127.0.0.1",
      "protocol": "vless",
      "settings": {
        "clients": [
          {
            "id": "d3f1a2b4-7e5c-4f8b-9c1d-2a3b4e5f6a7b",
            "level": 0
          }
        ],
        "decryption": "none"
      },
      "streamSettings": {
        "network": "xhttp",
        "xhttpSettings": {
          "path": "/JonathanXH?ed=2560",
          "mode": "stream-up",
          "scMaxEachPostBytes": "8388608",
          "scMaxConcurrentPosts": 500,
          "scMinPostsIntervalMs": 5,
          "scMaxIdleTimeMs": 86400000,
          "scResponseHeaderTimeoutMs": 180000,
          "scKeepAliveTimeoutMs": 7200000
        }
      },
      "sniffing": {
        "enabled": true,
        "destOverride": ["http", "tls"]
      }
    }
  ],
  "outbounds": [
    {
      "protocol": "freedom",
      "tag": "direct"
    }
  ]
}
